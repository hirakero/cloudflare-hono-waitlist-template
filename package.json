{
  "name": "cloudflare-hono-waitlist-template",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "client": "bun run --bun astro dev",
    "build": "bun run --bun astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint 'src/**/*.{js,ts,tsx,astro}'",
    "worker": "wrangler dev",
    "dev": "concurrently \"bun run client\" \"bun run worker\""
  },
  "dependencies": {
    "@astrojs/react": "^6.0.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.62.1",
    "astro": "^7.0.4",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "hono": "^4.12.27",
    "lucide-react": "^1.22.0",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "wrangler": "^4.106.0"
  },
  "devDependencies": {
    "daisyui": "^5.6.6",
    "prettier-plugin-tailwindcss": "^0.8.0"
  }
}
